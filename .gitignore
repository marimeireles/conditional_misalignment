# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/

# Local secrets (use .secret.example as template)
.secret

# Caches produced by eval / judge calls
**/cache/
**/llmcomp_cache/
**/.llmcomp_cache/

# Tinker run artifacts
**/tinker_logs_*/
tinker_sampler_path_*.txt

# Logs
*.log

# Evaluation artifacts (regenerated by running the eval scripts)
**/results/
**/results_*/
**/raw_results_*.csv
**/judged_results.csv
**/misaligned_examples/
**/figs/
*.png
*.pdf
*.svg

# Allow figures intentionally checked in under assets/
!assets/*.png
!assets/*.pdf

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Local reproduction (open-weight models on slurm)
cm-env/
vllm-env/
logs/
local_repro/runs/
local_repro/samples/
